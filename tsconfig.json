{
  "extends": "@gilbarbara/tsconfig",
  "compilerOptions": {
    "module": "Preserve",
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "~/*": ["./src/*"]
    },
    "outDir": "./dist",
    "rootDir": ".",
    "target": "ES2020",
    "types": ["node"]
  },
  "include": ["src/**/*"]
}
